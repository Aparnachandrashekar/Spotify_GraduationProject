# Spotify Web API (Client Credentials flow)
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google Gemini API (Google AI Studio)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq API (recommended for free-tier — generous limits, no credit card)
# https://console.groq.com/keys
# If GROQ_API_KEY is set, Groq is used instead of Gemini.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — force provider: groq | gemini
# LLM_PROVIDER=groq

# Optional — primary model (default: gemini-2.5-flash-lite, best free-tier quota)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional — comma-separated fallbacks when the primary hits quota (separate daily pool)
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite

# Optional — Spotify market for preview URLs (default: US)
# SPOTIFY_MARKET=US

# Vercel: add the three required vars above in Project Settings → Environment Variables
# Never use NEXT_PUBLIC_ for API keys — server-only only.
